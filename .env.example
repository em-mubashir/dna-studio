# Database
DATABASE_URI=mongodb://localhost:27017/dna-media

# Payload CMS
PAYLOAD_SECRET=your-secret-key-here-change-in-production
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Payload Admin (optional - defaults to /admin)
# PAYLOAD_PUBLIC_ADMIN_PATH=/admin

# Email (Resend API)
RESEND_API_KEY=your-resend-api-key-here

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=your-upstash-redis-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# Error Tracking (Sentry)
SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Analytics (Google Analytics 4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-ga-measurement-id-here

# Environment
NODE_ENV=development

#S3
S3_BUCKET=dna-media
S3_REGION=nyc3
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
